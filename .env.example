# Nusxa: cp .env.example .env  so‘ng qiymatlarni to‘ldiring (VM public IP yoki domen).

# Brauzer va tashqi so‘rovlar uchun bitta manzil (nginx 80-port, keyin HTTPS qo‘shsangiz shu domen)
NEXT_PUBLIC_SERVER_URL=http://YOUR_VM_IP
NEXTAUTH_URL=http://YOUR_VM_IP
CLIENT_URL=http://YOUR_VM_IP

NEXTAUTH_SECRET=changeme-long-random-string
# API va Next server action (generateToken) bir xil JWT_SECRET ishlatadi — ikkalasi ham .env dan olinadi.
JWT_SECRET=use-one-strong-random-string
NEXT_PUBLIC_JWT_SECRET=use-one-strong-random-string
ADMIN_SIGNUP_KEY=changeme-admin-signup-key

# Docker compose ichidagi Mongo (tashqi cluster ishlatsangiz, mongo servisini compose dan olib tashlang)
MONGO_URI=mongodb://mongo:27017/ecommerce

# Ixtiyoriy: Telegram kontakt formasi (Next)
# TELEGRAM_CONTACT_BOT_TOKEN=
# TELEGRAM_CONTACT_CHAT_ID=

# Ixtiyoriy: SMS.ru (server OTP)
# SMS_RU_API_ID=
# SMS_RU_FROM=

# Ixtiyoriy: Yandex Object Storage (S3-ga mos)
# S3_REGION=ru-central1
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
